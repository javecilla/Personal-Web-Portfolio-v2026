<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<!-- Preconnect to CDN for background pattern -->
<link rel="preconnect" href="https://s.cdpn.io" crossorigin>
<!-- Preload LCP image -->
<link rel="preload" as="image" href="/assets/me111.webp" fetchpriority="high">
<!-- Favicon -->
<link rel="icon" href="{{ "/assets/favicon.ico" | url }}" type="image/x-icon" sizes="32x32">
<link rel="shortcut icon" href="{{ "/favicon.ico" | url }}" type="image/x-icon">
<link rel="apple-touch-icon" href="{{ "/assets/favicon.ico" | url }}">
<link rel="sitemap" type="application/xml" href="{{ "/sitemap.xml" | url }}"/>

{% if googleVerification %}<meta name="google-site-verification" content="RAw3XoeQlQcldgqkMijkj8jMucAoJTaY_Ns44cioVfM" />{% endif %}

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-BHPREYCBLP"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-BHPREYCBLP');
</script>

<!-- Primary Meta Tags -->
<title>{{ title | default: site.title | default: "Portfolio - Javecilla" }}</title>
<meta name="title" content="{{ title | default: site.title | default: "Portfolio - Javecilla" }}"/>
<meta name="description" content="{{ description | default: site.description | default: "Personal website serves as a digital portfolio, showcasing my projects, skills, and experiences. This project is a testament to my passion for web development and design." }}" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website"/>
<meta property="og:url" content="{{ page.url | url | prepend: 'https://javecilla.vercel.app' }}">
<meta property="og:title" content="{{ title | default: site.title | default: "Portfolio - Javecilla" }}"/>
<meta property="og:description" content="{{ description | default: site.description | default: "Personal website serves as a digital portfolio, showcasing my projects, skills, and experiences." }}" />
<meta property="og:image" content="{{ featureImage | default: "https://javecilla.vercel.app/assets/projects/portfolio-website.webp" }}" />
<meta property="og:site_name" content="{{ site.title | default: "Portfolio - Javecilla" }}"/>

<!-- X (Twitter) -->
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:site" content="@_javecilla"/>
<meta name="twitter:creator" content="@_javecilla"/>
<meta name="twitter:title" content="{{ title | default: site.title | default: "Portfolio - Javecilla" }}"/>
<meta name="twitter:description" content="{{ description | default: site.description | default: "Personal website serves as a digital portfolio, showcasing my projects, skills, and experiences." }}"/>
<meta name="twitter:image" content="{{ featureImage | default: "https://javecilla.vercel.app/assets/projects/portfolio-website.webp" }}">

<!-- Additional SEO Tags -->
<meta name="msapplication-TileColor" content="#000000">
<meta name="theme-color" content="#ffffff" />
<meta name="color-scheme" content="light" />
<link rel='canonical' href="{{ page.url | url }}" />
<link rel="alternate" type="application/rss+xml" title="An IT student with a professional mindset, actively building my career as a Full-Stack Web Developer. Based in the Philippines, I go beyond the classroom to architect and build robust web applications using Vue.js, TypeScript, and Laravel." href="https://jerome-avecilla.vercel.app/" />

<!-- Mobile App Meta Tags -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black" />
<meta name="apple-mobile-web-app-title" content="{{ "Portfolio - Javecilla" | default: site.title }}" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black" />
<meta name="apple-mobile-web-app-title" content="{{ "Portfolio - Javecilla" | default: site.title }}" />

<!-- Preload Fonts -->
<link rel="preload" href="/src/fonts/MonumentExtended-Regular.woff2" crossorigin="anonymous" as="font" type="font/woff2">
<link rel="preload" href="/src/fonts/MonumentExtended-Regular.woff" crossorigin="anonymous" as="font" type="font/woff">
<link rel="preload" href="/src/fonts/SuisseIntl-Regular.woff2" crossorigin="anonymous" as="font" type="font/woff2">
<link rel="preload" href="/src/fonts/Canela-Regular.woff2" crossorigin="anonymous" as="font" type="font/woff2">

<link rel="stylesheet" href="{{ '/css/main.css' | url }}" rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="stylesheet" href="{{ '/css/splitting.css' | url }}" rel="preload" as="style">
<link rel="stylesheet" href="{{ '/css/splitting-cells.css' | url }}" rel="preload" as="style">
<noscript>
    <link
        href="{{ '/css/main.css' | url }}"
        rel="stylesheet"
        type="text/css"
    />
</noscript>

